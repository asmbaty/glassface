<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!--
    GlassFace for Windows — WinUI 3 (Windows App SDK) desktop app in C++/WinRT.
    This is a hand-authored equivalent of the Visual Studio 2022 "Blank App, Packaged
    (WinUI 3 in Desktop)" C++ template. Open it in VS 2022 (with the "Windows App SDK
    C++ Templates" / "Desktop development with C++" workload) and let NuGet restore the
    referenced packages, then Build.
  -->

  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration><Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration><Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Debug|ARM64">
      <Configuration>Debug</Configuration><Platform>ARM64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|ARM64">
      <Configuration>Release</Configuration><Platform>ARM64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <CppWinRTOptimized>true</CppWinRTOptimized>
    <CppWinRTRootNamespaceAutoMerge>true</CppWinRTRootNamespaceAutoMerge>
    <CppWinRTUsePrefixes>true</CppWinRTUsePrefixes>
    <MinimalCoreWin>true</MinimalCoreWin>
    <ProjectGuid>{1B2A3C4D-5E6F-4A7B-8C9D-0E1F2A3B4C5D}</ProjectGuid>
    <RootNamespace>GlassFace</RootNamespace>
    <ProjectName>GlassFace</ProjectName>
    <DefaultLanguage>en-US</DefaultLanguage>
    <WindowsTargetPlatformVersion>10.0.22621.0</WindowsTargetPlatformVersion>
    <WindowsTargetPlatformMinVersion>10.0.17763.0</WindowsTargetPlatformMinVersion>
    <UseWinUI>true</UseWinUI>
    <WindowsPackageType>MSIX</WindowsPackageType>
    <EnableMsixTooling>true</EnableMsixTooling>
    <AppxPackage>true</AppxPackage>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <PlatformToolset>v143</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)'=='Debug'" Label="Configuration">
    <UseDebugLibraries>true</UseDebugLibraries>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)'=='Release'" Label="Configuration">
    <UseDebugLibraries>false</UseDebugLibraries>
    <WholeProgramOptimization>true</WholeProgramOptimization>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <PropertyGroup>
    <GenerateManifest>true</GenerateManifest>
    <EmbedManifest>true</EmbedManifest>
    <!-- The Windows App SDK + CppWinRT NuGet packages auto-import the WinUI/XAML build
         logic via PackageReference build assets. -->
  </PropertyGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <PrecompiledHeader>Use</PrecompiledHeader>
      <PrecompiledHeaderFile>pch.h</PrecompiledHeaderFile>
      <LanguageStandard>stdcpp20</LanguageStandard>
      <AdditionalOptions>%(AdditionalOptions) /bigobj /await</AdditionalOptions>
      <SDLCheck>true</SDLCheck>
      <WarningLevel>Level4</WarningLevel>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <AdditionalDependencies>windowsapp.lib;gdiplus.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>

  <!-- Precompiled header -->
  <ItemGroup>
    <ClInclude Include="pch.h" />
    <ClCompile Include="pch.cpp">
      <PrecompiledHeader>Create</PrecompiledHeader>
    </ClCompile>
  </ItemGroup>

  <!-- XAML application object -->
  <ItemGroup>
    <ApplicationDefinition Include="App.xaml" />
    <Midl Include="App.idl" />
    <ClInclude Include="App.xaml.h" />
    <ClCompile Include="App.xaml.cpp" />
  </ItemGroup>

  <!-- App logic (plain C++/WinRT classes, no XAML metadata) -->
  <ItemGroup>
    <ClInclude Include="Sources\AppConfiguration.h" />
    <ClInclude Include="Sources\NativeHelpers.h" />
    <ClInclude Include="Sources\CameraService.h" />
    <ClInclude Include="Sources\OverlayWindow.h" />
    <ClInclude Include="Sources\ScreenOverlay.h" />
    <ClInclude Include="Sources\OverlayCoordinator.h" />
    <ClInclude Include="Sources\HotKeyCenter.h" />
    <ClInclude Include="Sources\StatusMenu.h" />
    <ClInclude Include="Sources\GhostIcon.h" />
    <ClInclude Include="Sources\AlertPresenter.h" />
    <ClInclude Include="Sources\AppCoordinator.h" />

    <ClCompile Include="Sources\NativeHelpers.cpp" />
    <ClCompile Include="Sources\CameraService.cpp" />
    <ClCompile Include="Sources\OverlayWindow.cpp" />
    <ClCompile Include="Sources\ScreenOverlay.cpp" />
    <ClCompile Include="Sources\OverlayCoordinator.cpp" />
    <ClCompile Include="Sources\HotKeyCenter.cpp" />
    <ClCompile Include="Sources\StatusMenu.cpp" />
    <ClCompile Include="Sources\GhostIcon.cpp" />
    <ClCompile Include="Sources\AppCoordinator.cpp" />
  </ItemGroup>

  <!-- Packaging + Win32 manifest -->
  <ItemGroup>
    <AppxManifest Include="Package.appxmanifest">
      <SubType>Designer</SubType>
    </AppxManifest>
    <Manifest Include="app.manifest" />
  </ItemGroup>

  <!-- Package assets (placeholder logos; replace with real artwork as desired) -->
  <ItemGroup>
    <Content Include="Assets\SplashScreen.png" />
    <Content Include="Assets\LockScreenLogo.png" />
    <Content Include="Assets\Square150x150Logo.png" />
    <Content Include="Assets\Square44x44Logo.png" />
    <Content Include="Assets\Square44x44Logo.targetsize-24_altform-unplated.png" />
    <Content Include="Assets\StoreLogo.png" />
    <Content Include="Assets\Wide310x150Logo.png" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Windows.CppWinRT" Version="2.0.240111.5" />
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.5.240607001" />
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.22621.3233" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />

</Project>
